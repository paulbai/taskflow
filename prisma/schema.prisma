generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  hashedPassword String
  avatar         String?
  createdAt      DateTime     @default(now())

  ownedLists           List[]             @relation("ListOwner")
  memberships          ListMember[]
  createdTasks         Task[]             @relation("TaskCreator")
  assignedTasks        Task[]             @relation("TaskAssignee")
  ownedWorkspaces      Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  createdBoards        Board[]            @relation("BoardCreator")
  createdPages         Page[]             @relation("PageCreator")
  comments             Comment[]
  notifications        Notification[]
}

model List {
  id        String       @id @default(cuid())
  name      String
  icon      String       @default("📝")
  createdAt DateTime     @default(now())

  ownerId   String
  owner     User         @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members   ListMember[]
  tasks     Task[]

  inviteCode String?     @unique
}

model ListMember {
  id     String @id @default(cuid())
  role   String @default("member") // "owner" | "member"

  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([userId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // "todo" | "in_progress" | "done"
  priority    String    @default("none") // "none" | "low" | "medium" | "high"
  startDate   String?
  dueDate     String?
  tags        String    @default("[]") // JSON array stored as string
  links       String    @default("[]") // JSON array of {title, url} objects
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listId      String?
  list        List?     @relation(fields: [listId], references: [id], onDelete: Cascade)

  boardId     String?
  board       Board?    @relation(fields: [boardId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User      @relation("TaskCreator", fields: [createdById], references: [id])

  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])

  inviteCode  String?   @unique

  subtasks    Subtask[]

  @@index([listId])
  @@index([boardId])
  @@index([createdById])
  @@index([assigneeId])
  @@index([status])
}

model Subtask {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)

  taskId      String
  task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("team") // "company" | "family" | "team" | "other"
  description String?
  slug        String?  @unique
  iconEmoji   String   @default("🏢")
  createdAt   DateTime @default(now())

  ownerId     String
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members     WorkspaceMember[]
  boards      Board[]
  pages       Page[]
  databases   Database[]

  inviteCode  String?  @unique
}

model WorkspaceMember {
  id     String @id @default(cuid())
  role   String @default("member") // "owner" | "admin" | "member"

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User     @relation("BoardCreator", fields: [createdById], references: [id])

  tasks       Task[]

  inviteCode  String?  @unique
}

// ── Office OS models ────────────────────────────────────────────

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String?
  title       String    @default("Untitled")
  iconEmoji   String?
  coverUrl    String?
  content     String? // Block-based content stored as JSON string
  isPublic    Boolean   @default(false)
  isArchived  Boolean   @default(false)
  isFavorite  Boolean   @default(false)
  isPrivate   Boolean   @default(false)
  position    Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Page?     @relation("PageChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Page[]    @relation("PageChildren")
  comments    Comment[]
  createdBy   User      @relation("PageCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([parentId])
  @@index([createdById])
}

model Database {
  id          String        @id @default(cuid())
  workspaceId String
  title       String
  iconEmoji   String?
  schema      String // JSON array of property definitions
  defaultView String        @default("table") // "table" | "board" | "calendar" | "gallery" | "list"
  isTaskDb    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rows        DatabaseRow[]

  @@index([workspaceId])
}

model DatabaseRow {
  id         String   @id @default(cuid())
  databaseId String
  data       String // JSON key-value pairs matching schema
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model Comment {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  parentId  String?
  content   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([pageId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "mention" | "comment" | "assigned" | "invited"
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

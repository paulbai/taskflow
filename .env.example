# Database (LibSQL / Turso)
DATABASE_URL="file:./dev.db"

# NextAuth.js
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis (rate limiting + live presence) — optional locally,
# strongly recommended in production. Create a free db at upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Anthropic API (AI assistant: summarize, improve, ask) — optional.
# Get a key at console.anthropic.com. AI features show a setup notice when unset.
ANTHROPIC_API_KEY=""

# Resend (password reset emails) — optional but recommended for production.
# Get a key at resend.com. Without it, /forgot-password shows a contact-owner notice.
RESEND_API_KEY=""
# Verified sender, e.g. "TaskFlow <noreply@yourdomain.com>"
EMAIL_FROM=""

# Vercel Blob (file uploads for task deliverables) — optional.
# Create a Blob store in the Vercel dashboard (Storage tab); the token is added
# automatically when linked to the project. Without it, links still work.
BLOB_READ_WRITE_TOKEN=""
